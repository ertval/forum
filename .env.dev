# Development environment variables for the forum application.
# Source this file in your shell before running the app: source .env.dev
# Or use a tool like direnv to auto-load it.

# Server configuration
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_TLS_PORT=8443
SERVER_ENVIRONMENT=development
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# Database configuration
DATABASE_PATH=./data/forum.db
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=25
DATABASE_CONN_MAX_LIFETIME=5m

# Session configuration
SESSION_SECRET=dev-secret-change-in-production
SESSION_DURATION=24h
SESSION_COOKIE_NAME=forum_session
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# Security configuration
TLS_CERT_FILE=cert.pem
TLS_KEY_FILE=key.pem
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
MIN_PASSWORD_LENGTH=8

# Upload configuration
UPLOAD_MAX_SIZE_MB=20
UPLOAD_DIR=./uploads

# OAuth configuration (optional - leave empty for basic auth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=