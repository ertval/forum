# Development environment variables for the forum application.
# Source this file in your shell before running the app: source .env.dev
# Or use a tool like direnv to auto-load it.

# Server configuration
SERVER_HOST=localhost                      # Hostname or IP address the server binds to
SERVER_PORT=8080                           # HTTP port for non-TLS connections
SERVER_TLS_PORT=8443                       # HTTPS port for TLS connections
SERVER_ENVIRONMENT=development             # Environment mode: development, staging, or production
SERVER_READ_TIMEOUT=15s                    # Maximum duration for reading the entire request
SERVER_WRITE_TIMEOUT=15s                   # Maximum duration before timing out writes of the response
SERVER_IDLE_TIMEOUT=60s                    # Maximum time to wait for the next request when keep-alives are enabled

# Database configuration
DATABASE_PATH=./data/forum.db              # Path to SQLite database file
DATABASE_MAX_OPEN_CONNS=25                 # Maximum number of open connections to the database
DATABASE_MAX_IDLE_CONNS=25                 # Maximum number of idle connections in the pool
DATABASE_CONN_MAX_LIFETIME=5m              # Maximum amount of time a connection may be reused

# Session configuration
SESSION_SECRET=dev-secret-change-in-production  # Secret key for signing session cookies (change in production!)
SESSION_DURATION=24h                       # How long sessions remain valid
SESSION_COOKIE_NAME=session_token          # Name of the session cookie
SESSION_SECURE=false                       # Whether to set Secure flag on cookies (true for HTTPS only)
SESSION_HTTP_ONLY=true                     # Whether to set HttpOnly flag (prevents JavaScript access)

# Security configuration
TLS_CERT_FILE=./certs/cert.pem             # Path to TLS certificate file (use Let's Encrypt in production)
TLS_KEY_FILE=./certs/key.pem               # Path to TLS private key file
RATE_LIMIT_REQUESTS=100                    # Maximum number of requests per IP within the time window
RATE_LIMIT_WINDOW=1m                       # Time window for rate limiting
MIN_PASSWORD_LENGTH=8                      # Minimum required password length for user accounts

# Upload configuration
UPLOAD_MAX_SIZE_MB=20                      # Maximum file upload size in megabytes
UPLOAD_DIR=./uploads                       # Directory where uploaded files are stored

# OAuth configuration (optional - leave empty for basic auth)
GOOGLE_OAUTH_CLIENT_ID=                    # Google OAuth 2.0 client ID
GOOGLE_OAUTH_CLIENT_SECRET=                # Google OAuth 2.0 client secret
GOOGLE_OAUTH_REDIRECT_URL=                 # Google OAuth 2.0 redirect URL
GITHUB_OAUTH_CLIENT_ID=                    # GitHub OAuth client ID
GITHUB_OAUTH_CLIENT_SECRET=                # GitHub OAuth client secret
GITHUB_OAUTH_REDIRECT_URL=                 # GitHub OAuth redirect URL