## Development Workflow

### During Development
1. Make code changes
2. Run relevant test suite:
   ```bash
   # API changes
   ./scripts/test_api.sh -v
   
   # Template/HTML changes
   ./scripts/test_pages.sh -v
   ```

### Before Commit
```bash
# Run full suite
./scripts/e2e_test.sh -v
```

### Quick Iteration
```bash
# Run specific test by commenting out others
# Edit test script to focus on failing test
./scripts/test_api.sh -v
```

---

## Troubleshooting

### Server Won't Start
```bash
# Check logs
cat /tmp/forum_*_server_*.log

# Manually check port
lsof -i :8080

# Build manually
go build -o bin/forum cmd/forum/main.go
./bin/forum
```

### Tests Timing Out
- Increase `max_attempts` in `wait_for_server()` function
- Check database migrations are completing
- Verify sufficient system resources

### Permission Errors
```bash
# Make scripts executable
chmod +x scripts/*.sh
```

### Database Lock Issues
- Tests use isolated timestamps for unique data
- Each script creates fresh test users
- If issues persist, check SQLite busy timeout settings

---

## Creating New Test Scripts

### Overview

All test scripts in this directory follow a strict pattern to ensure:
- **Idempotency**: Can be run multiple times without side effects
- **Independence**: Each script manages its own server and data
- **Isolation**: Tests clean up ALL data they create
- **Consistency**: Follow the same structure and conventions

### Test Script Structure Template

Use this template when creating new audit test scripts:

```bash
#!/bin/bash
# =============================================================================
# [FEATURE NAME] AUDIT TEST SCRIPT
# Tests per docs/requirements/audit-[feature].md
# =============================================================================

set -e

# =============================================================================
# CONFIGURATION
# =============================================================================
BASE_URL="http://localhost:8080"
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
DB_PATH="${PROJECT_ROOT}/data/forum.db"
SESSION_COOKIE=""
SESSION_COOKIE_FILE="/tmp/forum_[feature]_audit_session.txt"
SERVER_PID=""
SERVER_LOG="/tmp/forum_[feature]_audit_server.log"

# Test credentials (from seed data)
TEST_EMAIL="testuser@example.com"
TEST_PASSWORD="password123"
TEST_EMAIL2="testuser2@example.com"

# Colors for output
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

PASSED=0
FAILED=0

# Arrays to track created test data for cleanup
CREATED_POSTS=()
CREATED_COMMENTS=()
CREATED_USERS=()

# =============================================================================
# HELPER FUNCTIONS
# =============================================================================
print_section() {
    echo ""
    echo -e "${YELLOW}=== $1 ===${NC}"
    echo ""
}

print_question() {
    echo -e "${BLUE}Q:${NC} $1"
}

print_answer() {
    local status="$1"
    local answer="$2"
    if [ "$status" = "YES" ]; then
        echo -e "${GREEN}A: YES${NC} - $answer"
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}A: NO${NC} - $answer"
        FAILED=$((FAILED + 1))
    fi
    echo ""
}

extract_session_cookie() {
    echo "$1" | grep -i "set-cookie" | grep "session_token" | sed 's/.*session_token=\([^;]*\).*/\1/' | head -n 1
}

extract_json_field() {
    echo "$1" | grep -o "\"$2\":\"[^\"]*\"" | sed "s/\"$2\":\"\([^\"]*\)\"/\1/" | head -n 1
}

check_server_running() {
    lsof -Pi :8080 -sTCP:LISTEN -t >/dev/null 2>&1
}

kill_existing_server() {
    if check_server_running; then
        echo "Stopping existing server..."
        pkill -f "forum" 2>/dev/null || true
        sleep 2
    fi
}

start_server() {
    echo "Starting forum server..."
    if [ ! -f "${PROJECT_ROOT}/bin/forum" ]; then
        echo "Building forum binary..."
        cd "$PROJECT_ROOT" && go build -o bin/forum cmd/forum/main.go
    fi
    "${PROJECT_ROOT}/bin/forum" > "$SERVER_LOG" 2>&1 &
    SERVER_PID=$!
    
    # Wait for server to be ready (max 30 seconds)
    for i in {1..30}; do
        if curl -s "$BASE_URL/health-api" > /dev/null 2>&1 || curl -s "$BASE_URL/" > /dev/null 2>&1; then
            echo "Server ready!"
            return 0
        fi
        sleep 1
    done
    echo -e "${RED}Server failed to start${NC}"
    cat "$SERVER_LOG"
    exit 1
}

cleanup() {
    echo ""
    echo -e "${YELLOW}--- CLEANUP ---${NC}"
    echo ""
    
    # Re-login to get a fresh session for cleanup
    if [ -n "$SESSION_COOKIE" ] || [ ${#CREATED_POSTS[@]} -gt 0 ] || [ ${#CREATED_COMMENTS[@]} -gt 0 ]; then
        RESPONSE=$(curl -s -i -X POST "$BASE_URL/api/auth/login" \
            -H "Content-Type: application/json" \
            -d "{\"email\":\"$TEST_EMAIL\",\"password\":\"$TEST_PASSWORD\"}" 2>/dev/null)
        CLEANUP_SESSION=$(extract_session_cookie "$RESPONSE")
        
        if [ -n "$CLEANUP_SESSION" ]; then
            # Delete created posts (cascades to comments and reactions)
            for post_id in "${CREATED_POSTS[@]}"; do
                if [ -n "$post_id" ]; then
                    curl -s -X DELETE "$BASE_URL/api/posts/$post_id" \
                        -H "Cookie: session_token=$CLEANUP_SESSION" > /dev/null 2>&1
                fi
            done
            
            # Delete created comments (if not already deleted via cascade)
            for comment_id in "${CREATED_COMMENTS[@]}"; do
                if [ -n "$comment_id" ]; then
                    curl -s -X DELETE "$BASE_URL/api/comments/$comment_id" \
                        -H "Cookie: session_token=$CLEANUP_SESSION" > /dev/null 2>&1
                fi
            done
        fi
    fi
    
    # Clean up test users from database directly
    if [ ${#CREATED_USERS[@]} -gt 0 ]; then
        echo "Cleaning up ${#CREATED_USERS[@]} test user(s)..."
    fi
    for username in "${CREATED_USERS[@]}"; do
        if [ -n "$username" ]; then
            sqlite3 "$DB_PATH" "DELETE FROM sessions WHERE user_id IN (SELECT id FROM users WHERE username='$username');" 2>/dev/null
            sqlite3 "$DB_PATH" "DELETE FROM users WHERE username='$username';" 2>/dev/null
        fi
    done
    
    echo -e "${GREEN}✓ Test data cleaned up${NC}"
    
    # Stop server
    if [ -n "$SERVER_PID" ]; then
        kill $SERVER_PID 2>/dev/null || true
    fi
    rm -f "$SESSION_COOKIE_FILE"
}

trap cleanup EXIT

# =============================================================================
# MAIN SCRIPT
# =============================================================================
echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}[FEATURE NAME] AUDIT VERIFICATION${NC}"
echo -e "${YELLOW}Tests per docs/requirements/audit-[feature].md${NC}"
echo -e "${YELLOW}========================================${NC}"

# Verify prerequisites
if [ ! -f "$DB_PATH" ]; then
    echo -e "${RED}ERROR: Database file not found at $DB_PATH${NC}"
    echo -e "${YELLOW}Please run: make seed${NC}"
    exit 1
fi

# Verify database has required data
USER_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM users;" 2>&1)
if [ $? -ne 0 ]; then
    echo -e "${RED}ERROR: Cannot query database. Database may be corrupted.${NC}"
    echo -e "${YELLOW}Please run: make seed${NC}"
    exit 1
fi

if [ "$USER_COUNT" -lt 1 ]; then
    echo -e "${RED}ERROR: Database is empty. No users found.${NC}"
    echo -e "${YELLOW}Please run: make seed${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Database verified (${USER_COUNT} users)${NC}"
echo ""

kill_existing_server
start_server

# =============================================================================
# TEST SECTIONS - Map directly to audit requirements
# =============================================================================

# For each question in audit-[feature].md, create a test:
# 1. print_section "Section Name"  # Major section from audit doc
# 2. print_question "Exact question from audit doc"
# 3. Perform the test
# 4. print_answer "YES" "Brief explanation" OR print_answer "NO" "Why it failed"

print_section "Example Section"

print_question "Does feature X work correctly?"
# Perform test logic here
RESPONSE=$(curl -s "$BASE_URL/api/endpoint")
if echo "$RESPONSE" | grep -q "expected"; then
    print_answer "YES" "Feature X works as expected"
else
    print_answer "NO" "Feature X response incorrect"
fi

# =============================================================================
# SUMMARY
# =============================================================================
echo ""
echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}[FEATURE] AUDIT SUMMARY${NC}"
echo -e "${YELLOW}========================================${NC}"
echo -e "${GREEN}Passed: $PASSED${NC}"
echo -e "${RED}Failed: $FAILED${NC}"
echo -e "Total: $((PASSED + FAILED))"
echo -e "${YELLOW}========================================${NC}"

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ All [feature] audit requirements verified!${NC}"
    exit 0
else
    echo -e "${YELLOW}⚠ Some [feature] requirements need attention${NC}"
    exit 1
fi
```

### Step-by-Step Guide to Create a New Test Script

#### 1. Choose Your Audit Document

Identify which audit requirement file you're testing:
- `docs/requirements/audit.md` - Core functionality
- `docs/requirements/audit-advanced.md` - Advanced features
- `docs/requirements/audit-authentication.md` - OAuth features
- `docs/requirements/audit-image.md` - Image uploads
- `docs/requirements/audit-moderation.md` - User roles and moderation
- `docs/requirements/audit-security.md` - HTTPS, TLS, security

#### 2. Name Your Script

Follow the naming convention: `test_audit_[feature].sh`

Examples:
- `test_audit.sh` - Core audit
- `test_audit_advanced.sh` - Advanced features
- `test_audit_image.sh` - Image uploads

#### 3. Copy the Template

```bash
cp scripts/tests/test_audit.sh scripts/tests/test_audit_[feature].sh
```

#### 4. Update Configuration Section

Modify these values for your feature:
- `SESSION_COOKIE_FILE` - Use unique temp file path
- `SERVER_LOG` - Use unique log file path
- Add any feature-specific credentials or URLs

#### 5. Map Audit Questions to Tests

**CRITICAL**: Each question in the audit document must have a corresponding test.

Open your audit document and for each question:

```bash
# From audit doc: "##### Try to login with Github."
# "###### Is it possible to enter the forum?"

print_section "OAuth Authentication"

print_question "Try to login with Github - Is it possible to enter the forum?"
# Test implementation
RESPONSE=$(curl -s "$BASE_URL/api/auth/oauth/github/callback?code=test")
if echo "$RESPONSE" | grep -q "session_token"; then
    print_answer "YES" "GitHub OAuth login works"
else
    print_answer "NO" "GitHub OAuth login failed"
fi
```

#### 6. Track Created Data

**IMPORTANT**: Track all data you create for cleanup:

```bash
# When creating a post
CREATED_POST_ID=$(extract_json_field "$RESPONSE" "id")
if [ -n "$CREATED_POST_ID" ]; then
    CREATED_POSTS+=("$CREATED_POST_ID")
fi

# When creating a user
CREATED_USERS+=("$TEST_USERNAME")

# When creating a comment
CREATED_COMMENTS+=("$COMMENT_ID")
```

#### 7. Implement Cleanup Function

The cleanup function is automatically called on script exit. Make sure it:
1. Deletes all created posts
2. Deletes all created comments
3. Deletes all created users from database
4. Stops the server
5. Removes temporary files

The template includes a complete cleanup function - just ensure you're tracking data correctly.

#### 8. Test Your Script

```bash
# Make executable
chmod +x scripts/tests/test_audit_[feature].sh

# Run it
./scripts/tests/test_audit_[feature].sh

# Verify cleanup - run it again, should work identically
./scripts/tests/test_audit_[feature].sh
```

#### 9. Verify Idempotency

Run the test multiple times in succession:

```bash
./scripts/tests/test_audit_[feature].sh && \
./scripts/tests/test_audit_[feature].sh && \
./scripts/tests/test_audit_[feature].sh
```

All runs should pass with identical results.

#### 10. Add to Master Test Runner

The `run_all_tests.sh` script automatically discovers and runs all `test_*.sh` scripts in alphabetical order. No changes needed!

### Best Practices

#### ✅ DO:
- **Map 1:1 with audit questions**: Every question in the audit document must have a test
- **Use seeded test credentials**: `testuser@example.com` / `password123`
- **Track ALL created data**: Add to `CREATED_POSTS`, `CREATED_COMMENTS`, `CREATED_USERS` arrays
- **Clean up in reverse order**: Delete posts (cascade deletes comments), then users
- **Use unique temporary files**: Include feature name in temp file paths
- **Start your own server**: Each script manages its own server instance
- **Verify prerequisites**: Check database exists and has data before starting
- **Print clear output**: Use `print_section`, `print_question`, `print_answer` consistently
- **Handle errors gracefully**: Use `set -e` and trap EXIT for cleanup
- **Test both positive and negative cases**: Verify success AND failure scenarios

#### ❌ DON'T:
- **Don't rely on external state**: Don't assume data from other tests exists
- **Don't skip cleanup**: Always clean up, even if test fails
- **Don't hardcode IDs**: Use UUIDs from API responses
- **Don't modify seed data**: Use seed data read-only, create your own test data
- **Don't leave data in database**: Clean up everything you create
- **Don't share server instances**: Each script starts and stops its own server
- **Don't skip prerequisite checks**: Always verify database before testing
- **Don't guess audit questions**: Copy questions exactly from audit documents

### Common Patterns

#### Login and Get Session

```bash
RESPONSE=$(curl -s -i -X POST "$BASE_URL/api/auth/login" \
    -H "Content-Type: application/json" \
    -d "{\"email\":\"$TEST_EMAIL\",\"password\":\"$TEST_PASSWORD\"}")
SESSION_COOKIE=$(extract_session_cookie "$RESPONSE")
```

#### Create a Post

```bash
RESPONSE=$(curl -s -X POST "$BASE_URL/api/posts" \
    -H "Content-Type: application/json" \
    -H "Cookie: session_token=$SESSION_COOKIE" \
    -d "{\"title\":\"Test Post\",\"content\":\"Content\",\"categories\":[\"general\"]}")
POST_ID=$(extract_json_field "$RESPONSE" "id")
CREATED_POSTS+=("$POST_ID")
```

#### Check API Response

```bash
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" "$BASE_URL/api/endpoint")
if [ "$HTTP_CODE" = "200" ]; then
    print_answer "YES" "Endpoint returns 200"
else
    print_answer "NO" "Endpoint returned $HTTP_CODE"
fi
```

#### Check Database State

```bash
COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM posts WHERE title='Test';")
if [ "$COUNT" -gt 0 ]; then
    print_answer "YES" "Post exists in database"
else
    print_answer "NO" "Post not found in database"
fi
```

#### Verify File Exists

```bash
if [ -f "$PROJECT_ROOT/path/to/file" ]; then
    print_answer "YES" "File exists"
else
    print_answer "NO" "File not found"
fi
```

### Testing Checklist

Before submitting your test script, verify:

- [ ] Script is executable (`chmod +x`)
- [ ] Follows naming convention `test_audit_[feature].sh` OR `test_[feature].sh`
- [ ] Maps to specific audit document in `docs/requirements/`
- [ ] Every audit question has a corresponding test
- [ ] Uses seeded test credentials from `testuser@example.com`
- [ ] Tracks all created data in arrays
- [ ] Implements complete cleanup function
- [ ] Cleanup is registered with `trap cleanup EXIT`
- [ ] Starts its own server instance
- [ ] Stops server in cleanup
- [ ] Verifies database prerequisites before running
- [ ] Uses unique temporary file paths
- [ ] Prints clear, colored output
- [ ] Returns proper exit codes (0 = pass, 1 = fail)
- [ ] Can be run multiple times (idempotent)
- [ ] Can run independently (no dependencies on other tests)
- [ ] Cleans up all data (verified by running twice)
- [ ] Includes summary section with pass/fail counts
- [ ] Handles server startup failures gracefully
- [ ] Has timeout protection (via trap)

### Example: Mapping Audit Document to Tests

Given this audit document section:

```markdown
#### Image Upload

##### Try creating a post with a PNG image.
###### Was the post created successfully?

##### Try creating a post with a JPEG image.
###### Was the post created successfully?

##### Try creating a post with an image larger than 20mb.
###### Were you warned that this was not possible?
```

Your test script should have:

```bash
print_section "Image Upload"

# Question 1
print_question "Try creating a post with a PNG image - Was it created successfully?"
PNG_FILE="/tmp/test.png"
# Create test PNG
convert -size 100x100 xc:blue "$PNG_FILE"
RESPONSE=$(curl -s -X POST "$BASE_URL/api/posts" \
    -H "Cookie: session_token=$SESSION_COOKIE" \
    -F "title=PNG Test" \
    -F "content=Testing PNG" \
    -F "image=@$PNG_FILE")
POST_ID=$(extract_json_field "$RESPONSE" "id")
if [ -n "$POST_ID" ]; then
    CREATED_POSTS+=("$POST_ID")
    print_answer "YES" "PNG post created successfully"
else
    print_answer "NO" "Failed to create PNG post"
fi
rm -f "$PNG_FILE"

# Question 2
print_question "Try creating a post with a JPEG image - Was it created successfully?"
JPEG_FILE="/tmp/test.jpg"
# Create test JPEG
convert -size 100x100 xc:red "$JPEG_FILE"
RESPONSE=$(curl -s -X POST "$BASE_URL/api/posts" \
    -H "Cookie: session_token=$SESSION_COOKIE" \
    -F "title=JPEG Test" \
    -F "content=Testing JPEG" \
    -F "image=@$JPEG_FILE")
POST_ID=$(extract_json_field "$RESPONSE" "id")
if [ -n "$POST_ID" ]; then
    CREATED_POSTS+=("$POST_ID")
    print_answer "YES" "JPEG post created successfully"
else
    print_answer "NO" "Failed to create JPEG post"
fi
rm -f "$JPEG_FILE"

# Question 3
print_question "Try creating a post with >20MB image - Were you warned?"
# Create large file (21MB)
dd if=/dev/zero of=/tmp/large.png bs=1M count=21 2>/dev/null
RESPONSE=$(curl -s -X POST "$BASE_URL/api/posts" \
    -H "Cookie: session_token=$SESSION_COOKIE" \
    -F "title=Large Test" \
    -F "content=Testing large file" \
    -F "image=@/tmp/large.png")
if echo "$RESPONSE" | grep -qi "file.*too.*large\|size.*limit\|exceeded"; then
    print_answer "YES" "Size limit validation works"
else
    print_answer "NO" "No size limit warning"
fi
rm -f /tmp/large.png
```

